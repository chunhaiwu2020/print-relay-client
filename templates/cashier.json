{
  "width": 48,
  "lines": [
    {
      "text": "{{restaurant_name}}",
      "align": "center",
      "size": "wide",
      "bold": true
    },
    {
      "text": "Tisch {{table}}  #{{id}}",
      "align": "center",
      "bold": true
    },
    {
      "hr": "="
    },
    {
      "repeat": "items",
      "left": "{{qty}}x {{name}}",
      "right": "{{total}} EUR",
      "bold": true
    },
    {
      "hr": "="
    },
    {
      "text": "TOTAL: {{total_amount}} EUR",
      "align": "right",
      "size": "xl",
      "bold": true
    }
  ]
}