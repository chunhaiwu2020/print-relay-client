{
    "width": 48,
    "lines": [
        {"text": "{{restaurant_name}}", "align": "center", "size": "wide", "bold": true},
        {"text": "*** CAJA ***", "align": "center", "size": "xl", "bold": true},
        {"text": "Pedido #{{id}}", "align": "center"},
        {"text": "{{printed_at}}", "align": "center"},
        {"hr": "="},
        {"repeat": "items", "left": "{{qty}}x {{name}}", "right": "{{total}}"},
        {"hr": "="},
        {"text": "TOTAL: {{total_amount}} EUR", "align": "right", "size": "xl", "bold": true},
        {"text": "Pago: {{payment_method}}", "align": "center"}
    ]
}
