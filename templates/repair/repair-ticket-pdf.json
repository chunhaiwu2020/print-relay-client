{
  "name": "Repair Ticket PDF / 维修单 PDF",
  "industry": "Repair / 维修",
  "desc": "Full repair service ticket in PDF format",
  "format": "html",
  "width": 80,
  "html": "<!DOCTYPE html><html><head><meta charset='UTF-8'><style>@page{size:80mm auto;margin:0}body{font-family:'Segoe UI',Arial,sans-serif;font-size:10px;width:80mm;margin:0;padding:2mm;box-sizing:border-box}.c{text-align:center}.r{text-align:right}.b{font-weight:bold}.xl{font-size:16px}.l{font-size:9px;color:#555}.hr{border-top:1px dashed #888;margin:2mm 0}.row{display:flex;justify-content:space-between;margin:1px 0}.lb{color:#555}pre{font-size:9px;margin:0;white-space:pre-wrap}</style></head><body>%CONTENT%</body></html>",
  "content": [
    ["div", "c b xl", "{{shop_name}}"],
    ["condition", "shop_tax_id", "div", "c l", "DNI/NIE: {{shop_tax_id}}"],
    ["condition", "shop_phone", "div", "c l", "{{shop_phone}}"],
    ["condition", "shop_address", "div", "c l", "{{shop_address}}"],
    ["div", "hr", ""],
    ["div", "c b", "FICHA DE REPARACIÓN"],
    ["div", "c xl", "#{{ticket_no}}"],
    ["div", "row", "<span class='b'>Cliente:</span> <span>{{customer_name}}</span>"],
    ["condition", "id_document", "div", "row", "<span class='lb'>ID:</span> <span>{{id_document}}</span>"],
    ["condition", "customer_phone", "div", "row", "<span class='lb'>Tel:</span> <span>{{customer_phone}}</span>"],
    ["div", "hr", ""],
    ["condition", "device_model", "div", "row", "<span class='lb'>Modelo:</span> <span>{{device_model}}</span>"],
    ["condition", "imei", "div", "row", "<span class='lb'>IMEI:</span> <span class='l'>{{imei}}</span>"],
    ["div", "hr", ""],
    ["div", "b", "Avería:"],
    ["condition", "fault_desc", "div", "", "{{fault_desc}}"],
    ["condition", "checkin_result", "div", "l", "Recepción: {{checkin_result}}"],
    ["div", "hr", ""],
    ["condition", "estimated_price", "div", "r b", "Presupuesto: {{estimated_price}} €"],
    ["condition", "prepaid", "div", "r", "Anticipo: {{prepaid}} €"],
    ["condition", "technician", "div", "row", "<span class='lb'>Técnico:</span> <span>{{technician}}</span>"],
    ["condition", "notes", "div", "l", "Nota: {{notes}}"],
    ["div", "row", "<span class='lb'>Creado:</span> <span class='l'>{{created_at}}</span>"],
    ["condition", "pickup_at", "div", "row", "<span class='lb'>Recogida:</span> <span class='l'>{{pickup_at}}</span>"],
    ["div", "hr", ""],
    ["condition", "shop_terms", "div", "c l", "<pre>{{shop_terms}}</pre>"]
  ]
}
