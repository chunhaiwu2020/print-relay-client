{
  "width": 48,
  "lines": [
    {
      "text": "{{restaurant_name}}",
      "align": "center",
      "size": "wide",
      "bold": true
    },
    {
      "text": "Mesa {{table}}   Pedido {{id}}",
      "align": "center",
      "bold": true
    },
    {
      "text": "{{printed_at}}",
      "align": "center",
      "bold": true
    },
    {
      "hr": "="
    },
    {
      "repeat": "items",
      "left": "{{qty}} x {{item_code}} {{name}}",
      "right": "{{total}}",
      "bold": true
    },
    {
      "hr": "="
    },
    {
      "text": "TOTAL  {{total_amount}} EUR",
      "align": "right",
      "size": "xl",
      "bold": true
    },
    {
      "text": "Gracias / 谢谢惠顾",
      "align": "center",
      "bold": true
    }
  ]
}